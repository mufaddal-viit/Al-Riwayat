# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ─── Cookie ───────────────────────────────────────────────────────────────────
# Set to your domain in production (e.g. alriwayat.com). Leave blank for localhost.
COOKIE_DOMAIN=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave blank in development — emails will be printed to the console instead.
EMAIL_FROM=noreply@alriwayat.com
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
