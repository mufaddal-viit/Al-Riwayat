# ─── Site ─────────────────────────────────────────────────────────────────────
# Canonical site URL used for metadataBase, OG images, sitemap, canonical tags.
# Leave blank on Vercel previews — the app falls back to https://$VERCEL_URL.
# Set this explicitly in the Production environment (e.g. https://al-riwayaat.com).
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 measurement ID (optional). Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Backend API ──────────────────────────────────────────────────────────────
# Full base URL including the /api prefix. Used by both the client axios instance
# and the server-side issue fetcher (generateStaticParams / generateMetadata).
# Example: https://al-riwayat-production.up.railway.app/api
NEXT_PUBLIC_API_URL=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Firebase Web SDK ─────────────────────────────────────────────────────────
# From Firebase Console → Project Settings → General → Your apps (Web app) → SDK setup.
# All values are safe to expose in the browser bundle.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
